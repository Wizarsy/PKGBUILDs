# Maintainer: Filipe B. Madruga <filipemadruga@outlook.com>

pkgname=ananicy-cpp
pkgver=1.2.0
pkgrel=2
pkgdesc="Ananicy Cpp is a full rewrite of Ananicy in C++, featuring lower CPU and RAM usage."
arch=(x86_64)
url="https://gitlab.com/ananicy-cpp/ananicy-cpp"
license=('GPL-3.0-or-later')
depends=(
  glibc
  libgcc
  libbpf
  libelf
  "libfmt.so>=8.0"
  "libspdlog.so>=1.9"
  libstdc++
  pcre2
  zlib
)
makedepends=(
  gcc15
  bpf
  "clang>=10"
  "cmake>=3.17"
  git
  ninja
  "nlohmann-json>=3.9"
)
source=("git+https://gitlab.com/ananicy-cpp/ananicy-cpp.git#tag=v$pkgver")
sha256sums=('21f07abc1e7aff9e90767e1a831920a74ee2be49d16099b1484c48081376dcc6')

prepare() {
  cd "$srcdir/$pkgname"

  sed -i '1s/^/#include <unistd.h>\n/' src/platform/linux/process.cpp
  sed -i '1s/^/#include <unistd.h>\n/' src/platform/linux/debug.cpp
  sed -i '1s/^/#include <cstdint>\n/' src/platform/linux/backtrace.cpp
  sed -i '1s/^/#include <cstring>\n/' src/platform/linux/singleton_process.cpp
  sed -i '1s/^/#include <cstring>\n/' src/utility/argument_parsing/argument.cpp
}

build() {
  cd "$srcdir/$pkgname"

  export CXX="/usr/bin/g++-15"
  export CC="/usr/bin/gcc-15"
  
  cmake -S . -Bbuild \
        -GNinja \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DUSE_EXTERNAL_SPDLOG=ON \
        -DUSE_EXTERNAL_JSON=ON \
        -DUSE_EXTERNAL_FMTLIB=ON \
        -DENABLE_SYSTEMD=OFF \
        -DUSE_BPF_PROC_IMPL=ON \
        -DBPF_BUILD_LIBBPF=OFF \
        -DENABLE_REGEX_SUPPORT=ON \
        -DVERSION=${pkgver}

  cmake --build build --target ananicy-cpp
}

package() {
  cd "$srcdir/$pkgname"

  DESTDIR="${pkgdir}" cmake --install build --component Runtime

  install -m755 -d "${pkgdir}/etc/ananicy.d"
}
