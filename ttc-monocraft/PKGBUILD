# Maintainer: Filipe B. Madruga <filipemadruga@outlook.com>

pkgbase='ttc-monocraft'
pkgname=(
  'ttc-monocraft-nerd-fonts-patched'
  'ttc-monocraft-no-ligatures'
  'ttc-monocraft'
)
pkgver=4.2.1
pkgrel=1
pkgdesc='A monospaced programming font inspired by the Minecraft typeface'
arch=('any')
url='https://github.com/IdreesInc/Monocraft'
license=('OFL-1.1')
provides=('ttc-monocraft')
conflicts=('ttc-monocraft')
source=(
  "Monocraft-nerd-fonts-patched-$pkgver.ttc::https://github.com/IdreesInc/Monocraft/releases/download/v$pkgver/Monocraft-nerd-fonts-patched.ttc"
  "Monocraft-no-ligatures-$pkgver.ttc::https://github.com/IdreesInc/Monocraft/releases/download/v$pkgver/Monocraft-no-ligatures.ttc"
  "Monocraft-$pkgver.ttc::https://github.com/IdreesInc/Monocraft/releases/download/v$pkgver/Monocraft.ttc"
  "Monocraft-$pkgver-LICENSE::https://raw.githubusercontent.com/IdreesInc/Monocraft/refs/heads/main/LICENSE"
)
sha256sums=('67f88ff9e7c6560f6cf60fb062fd353a72f62dc2654462950c65b63ed53d9754'
            '93ee79ba62b7d0a653dfd90d5c519f949e3ad64ec483046b417f2cc6943831d0'
            '0ea1aea12f03d552a469fc017f19ea927b53bf9d21e60a41c5c476c3faf3c7f9'
            'f69c147003e052dbc9d96c40a9f73647e72766cfda95a597b94ed827fe25acb1')

package_ttc-monocraft-nerd-fonts-patched() {
  pkgdesc+=' (nerd fonts patched)'

  install -Dm644 Monocraft-$pkgver-LICENSE \
    "$pkgdir"/usr/share/licenses/$pkgbase/LICENSE

  install -Dm644 Monocraft-nerd-fonts-patched-$pkgver.ttc \
    "$pkgdir"/usr/share/fonts/TTC/Monocraft.ttc
}

package_ttc-monocraft-no-ligatures() {
  pkgdesc+=' (no ligatures)'

  install -Dm644 Monocraft-$pkgver-LICENSE \
    "$pkgdir"/usr/share/licenses/$pkgbase/LICENSE

  install -Dm644 Monocraft-no-ligatures-$pkgver.ttc \
    "$pkgdir"/usr/share/fonts/TTC/Monocraft.ttc
}

package_ttc-monocraft() {
  install -Dm644 Monocraft-$pkgver-LICENSE \
    "$pkgdir"/usr/share/licenses/$pkgbase/LICENSE

  install -Dm644 Monocraft-$pkgver.ttc \
    "$pkgdir"/usr/share/fonts/TTC/Monocraft.ttc
}
